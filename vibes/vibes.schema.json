{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vibes Playlist",
  "description": "A curated playlist of ambient media for coding sessions",
  "type": "object",
  "required": ["name", "entries"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the playlist"
    },
    "description": {
      "type": "string",
      "description": "Short description of the playlist vibe"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "url", "platform", "duration_minutes", "tags"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Display title for the media"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Direct URL to the media (for linking)"
          },
          "embed_url": {
            "type": "string",
            "format": "uri",
            "description": "Embeddable URL. Required for all platforms except 'text'"
          },
          "platform": {
            "type": "string",
            "enum": ["youtube", "spotify", "soundcloud", "apple_music", "arena", "bandcamp", "mixcloud", "vimeo", "text"],
            "description": "Media platform"
          },
          "duration_minutes": {
            "type": ["number", "null"],
            "minimum": 0,
            "description": "Duration in minutes. null for livestreams."
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Mood/genre tags for filtering (e.g. 'lofi', 'jazz', 'ambient')"
          },
          "text_content": {
            "type": "string",
            "description": "Body text for 'text' platform entries (poem, excerpt, quote)"
          },
          "text_author": {
            "type": "string",
            "description": "Author/source attribution for text entries"
          }
        }
      }
    }
  }
}
